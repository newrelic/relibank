{
  "name": "Azure OpenAI Assistants - Relibank Chatbot",
  "description": "Comprehensive monitoring for Azure OpenAI Assistants with agent-to-agent communication",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Overview",
      "description": "High-level metrics for Azure OpenAI Assistants",
      "widgets": [
        {
          "title": "Total Assistant Invocations",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) as 'Total Invocations' FROM AzureAssistantInvocation SINCE 1 day ago"
              }
            ]
          }
        },
        {
          "title": "Agent-to-Agent Call Rate",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE assistantBInvoked = true) as 'Agent-to-Agent %' FROM AzureAssistantInvocation WHERE assistantName = 'coordinator' SINCE 1 day ago"
              }
            ]
          }
        },
        {
          "title": "Total Cost (USD)",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(estimatedCost) as 'Total Cost' FROM AzureAssistantInvocation SINCE 1 day ago"
              }
            ],
            "thresholds": [
              {
                "alertSeverity": "WARNING",
                "value": 10
              },
              {
                "alertSeverity": "CRITICAL",
                "value": 50
              }
            ]
          }
        },
        {
          "title": "Invocations Over Time",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 8,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AzureAssistantInvocation SINCE 1 day ago FACET assistantName TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Success Rate",
          "layout": {
            "column": 9,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE status = 'success') as 'Success Rate %' FROM AzureAssistantInvocation SINCE 1 day ago"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Performance",
      "description": "Latency and performance metrics",
      "widgets": [
        {
          "title": "Average Latency by Assistant",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(latencyMs) as 'Avg Latency (ms)' FROM AzureAssistantInvocation SINCE 1 hour ago FACET assistantName"
              }
            ]
          }
        },
        {
          "title": "Latency Percentiles - Assistant A (Coordinator)",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 8,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentile(latencyMs, 50, 95, 99) FROM AzureAssistantInvocation WHERE assistantName = 'coordinator' SINCE 1 hour ago TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Latency Percentiles - Assistant B (Specialist)",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 8,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentile(latencyMs, 50, 95, 99) FROM AzureAssistantInvocation WHERE assistantName = 'specialist' SINCE 1 hour ago TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Assistant B Artificial Delay (Demo)",
          "layout": {
            "column": 9,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(artificialDelayMs) as 'Avg Delay (ms)' FROM AzureAssistantInvocation WHERE assistantName = 'specialist' SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Impact of Agent-to-Agent on Latency",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 12,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(latencyMs) as 'Overall Latency' FROM AzureAssistantInvocation WHERE assistantName = 'coordinator' SINCE 1 hour ago FACET assistantBInvoked TIMESERIES AUTO"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Agent Communication",
      "description": "Agent-to-agent interaction metrics",
      "widgets": [
        {
          "title": "Agent-to-Agent Calls",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AgentToAgentCall SINCE 1 day ago TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Agent Call Flow",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) as 'Call Count', latest(timestamp) as 'Last Call' FROM AgentToAgentCall SINCE 1 day ago FACET sourceAgent, targetAgent"
              }
            ]
          }
        },
        {
          "title": "Coordinator Requests with Specialist Involvement",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 12,
            "height": 3
          },
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AzureAssistantInvocation WHERE assistantName = 'coordinator' SINCE 1 day ago FACET assistantBInvoked"
              }
            ]
          }
        },
        {
          "title": "Recent Agent Interactions",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 12,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT timestamp, sourceAgent, targetAgent, functionName, threadId FROM AgentToAgentCall SINCE 1 hour ago LIMIT 50"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Cost Analysis",
      "description": "Token usage and cost tracking",
      "widgets": [
        {
          "title": "Cost Over Time",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 8,
            "height": 3
          },
          "visualization": {
            "id": "viz.area"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(estimatedCost) as 'Cost (USD)' FROM AzureAssistantInvocation SINCE 1 day ago FACET assistantName TIMESERIES 1 hour"
              }
            ]
          }
        },
        {
          "title": "Average Cost per Request",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(estimatedCost) as 'Avg Cost (USD)' FROM AzureAssistantInvocation SINCE 1 day ago FACET assistantName"
              }
            ]
          }
        },
        {
          "title": "Token Usage by Assistant",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(totalTokens) as 'Total Tokens' FROM AzureAssistantInvocation SINCE 1 day ago FACET assistantName TIMESERIES 1 hour"
              }
            ]
          }
        },
        {
          "title": "Cost Breakdown",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(estimatedCost) as 'Total Cost (USD)' FROM AzureAssistantInvocation SINCE 1 day ago FACET assistantName"
              }
            ]
          }
        },
        {
          "title": "Cost Impact of Agent-to-Agent",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 12,
            "height": 3
          },
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(estimatedCost) as 'Avg Cost', average(totalTokens) as 'Avg Tokens' FROM AzureAssistantInvocation WHERE assistantName = 'coordinator' SINCE 1 day ago FACET assistantBInvoked"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Errors & Debugging",
      "description": "Error tracking and debugging information",
      "widgets": [
        {
          "title": "Error Rate",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE status = 'error') as 'Error Rate %' FROM AzureAssistantInvocation SINCE 1 hour ago"
              }
            ],
            "thresholds": [
              {
                "alertSeverity": "WARNING",
                "value": 5
              },
              {
                "alertSeverity": "CRITICAL",
                "value": 10
              }
            ]
          }
        },
        {
          "title": "Errors Over Time",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 8,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AzureAssistantInvocation WHERE status = 'error' SINCE 1 day ago FACET assistantName TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Error Types",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT count(*) FROM AzureAssistantInvocation WHERE status = 'error' SINCE 1 day ago FACET errorType"
              }
            ]
          }
        },
        {
          "title": "Recent Errors",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT timestamp, assistantName, threadId, errorType FROM AzureAssistantInvocation WHERE status = 'error' SINCE 1 day ago LIMIT 20"
              }
            ]
          }
        }
      ]
    }
  ]
}
