# NRDOT MSSQL Collector Credentials
#
# This file is AUTO-GENERATED by a skaffold pre-deploy hook — do not edit it directly.
# The hook reads these variables from skaffold.env and writes nrdot-mssql.env:
#
#   skaffold.env variable      →  written to nrdot-mssql.env
#   ─────────────────────────────────────────────────────
#   MSSQL_NEWRELIC_PASSWORD    →  MSSQL_NEWRELIC_PASSWORD
#   NEW_RELIC_LICENSE_KEY      →  NEW_RELIC_LICENSE_KEY
#   NEW_RELIC_OTLP_ENDPOINT    →  NEW_RELIC_OTLP_ENDPOINT (defaults to https://otlp.nr-data.net)
#
# For CI/CD (GitHub Actions), the same variables are injected from the
# 'events' environment secrets into the skaffold.env created by the workflow:
#   secrets.MSSQL_NEWRELIC_PASSWORD  →  MSSQL_NEWRELIC_PASSWORD
#   secrets.NR_LICENSE_KEY           →  NEW_RELIC_LICENSE_KEY
#
# If you ever need to create this file manually:
MSSQL_NEWRELIC_PASSWORD=<your_mssql_newrelic_password>
NEW_RELIC_LICENSE_KEY=<your_license_key>
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net
