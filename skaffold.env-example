# OpenAI
OPENAI_LOG=info
OPENAI_API_KEY=key
OPENAI_BASE_URL=openai_url
OPENAI_API_TYPE=azure
OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI (support-service AI flows)
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com/
AZURE_OPENAI_API_KEY=AZURE_OPENAI_API_KEY

# New Relic
# NEW_RELIC_LICENSE_KEY is the APM ingest key (suffix: FFFFNRAL).
# NEW_RELIC_BROWSER_LICENSE_KEY is the *browser* ingest key (prefix: NRJS-).
# These are two DIFFERENT keys — see docs/secrets-reference.md.
NEW_RELIC_USER_API_KEY=NEW_RELIC_USER_API_KEY
NEW_RELIC_ACCOUNT_ID=NEW_RELIC_ACCOUNT_ID
NEW_RELIC_LICENSE_KEY=NEW_RELIC_LICENSE_KEY
NEW_RELIC_BROWSER_APPLICATION_ID=NEW_RELIC_BROWSER_APPLICATION_ID
NEW_RELIC_TRUST_KEY=NEW_RELIC_TRUST_KEY
NEW_RELIC_BROWSER_LICENSE_KEY=NRJS-*
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net
APP_NAME=your_name

# Azure Communication Services
AZURE_ACS_CONNECTION_STRING=
AZURE_ACS_SMS_PHONE_NUMBER=
AZURE_ACS_EMAIL_SENDER=
AZURE_FUNCTION_URL=

# MSSQL — used by skaffold pre-deploy hook to generate nrdot-mssql.env
MSSQL_NEWRELIC_PASSWORD=YourStrong@Password!

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Demo controls
ASSISTANT_B_DELAY_SECONDS=0
